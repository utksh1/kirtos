# ===============================
# Kirtos — Environment Variables
# ===============================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- LiveKit (Voice Transport) ---
# Sign up at https://livekit.io — free tier available
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_API_SECRET=your_livekit_api_secret

# --- OpenRouter / OpenAI (Intent Parsing) ---
# Sign up at https://openrouter.ai — many free models available
OPENAI_API_KEY=sk-or-v1-your_openrouter_api_key
OPENAI_BASE_URL=https://openrouter.ai/api/v1
INTENT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free

# --- Deepgram (Speech-to-Text) ---
# Sign up at https://deepgram.com — free tier available
DEEPGRAM_API_KEY=your_deepgram_api_key

# --- Cartesia (Text-to-Speech) ---
# Sign up at https://cartesia.ai
CARTESIA_API_KEY=sk_car_your_cartesia_api_key

# --- DigitalOcean AI Agent (Optional — fallback LLM) ---
# Only needed if you want a secondary AI fallback
# DO_AGENT_URL=https://your-agent-id.agents.do-ai.run
# DO_AGENT_KEY=your_do_agent_key

# ===============================
# Kirtos — Git Ignore
# ===============================

# --- Dependencies ---
node_modules/
package-lock.json

# --- Environment / Secrets ---
.env
.env.local
.env.*.local

# --- WhatsApp Auth (session credentials) ---
.whatsapp-auth/

# --- Python / NLP ---
.venv/
__pycache__/
*.pyc
agent/nlp/intent_model.pkl

# --- Build Output ---
dist/
dist-ssr/

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# --- OS Files ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- Editor / IDE ---
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Debug / Test Scripts ---
agent/debug_*.js
agent/verify_*.js
agent/test_*.js

# --- Misc ---
filelist.txt
*.local
